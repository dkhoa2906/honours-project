% Title section command
\newcommand{\reportTitle}[2]{
    \begin{center}
    \vspace*{2cm}
    
    \hdashrule{\textwidth}{1.5pt}{9pt} 
    \vspace{1.5cm}
    
    {\fontsize{20}{24}\selectfont\bfseries CMP6200\par}
    \vspace{0.3cm}

    {\fontsize{20}{24}\selectfont\bfseries Individual Undergraduate Project\par}
    \vspace{0.3cm}

    {\fontsize{20}{24}\selectfont\bfseries #1\par}
    \vspace{0.3cm}
    
    {\fontsize{20}{24}\selectfont\bfseries #2\par}
    
    \vspace{1.8cm}
    \hdashrule{\textwidth}{1.5pt}{9pt}
    \vspace{1.5cm}
    \end{center}
}

% Student info section command
\newcommand{\reportCredit}[5]{
    \begin{flushleft}
        {\fontsize{16.2}{18}\selectfont\bfseries Student Name:} {\fontsize{15.7}{18}\selectfont #1}\par
        \vspace{0.45cm}
        {\fontsize{16.2}{18}\selectfont\bfseries Student ID:} {\fontsize{15.7}{18}\selectfont #2}\par
        \vspace{0.45cm}
        {\fontsize{16.2}{18}\selectfont\bfseries Course:} {\fontsize{15.7}{18}\selectfont #3}\par
        \vspace{0.45cm}
        {\fontsize{16.2}{18}\selectfont\bfseries Supervisor:} {\fontsize{15.7}{18}\selectfont #4}\par
        \vspace{0.45cm}
        {\fontsize{16.2}{18}\selectfont\bfseries Date:} {\fontsize{15.7}{18}\selectfont\ #5}\par
    \end{flushleft}
    
}

% Combined command 
\newcommand{\reportTitlePage}[7]{
    \reportTitle{#1}{#2}
    \reportCredit{#3}{#4}{#5}{#6}{#7}
}

