    % \vspace*{-2.1cm}
    {\LARGE\bfseries\raggedright Abstract\par}
    \addcontentsline{toc}{chapter}{Abstract}
    \addtocontents{toc}{\vspace{-0.15cm}}
    \thispagestyle{fancy}
    \vspace{0.5cm}
    \setstretch{1.5}
    \setlength{\parskip}{9pt plus 2pt minus 1pt}
    #1
}


